# =================================================================
# DATABASE CONFIGURATION
# =================================================================
# Path to the SQLite database file inside the container.
# Use 4 slashes (sqlite:////) for absolute paths in Linux/Docker.
DATABASE_URL=sqlite:////app/data/database/financial_data.db

# =================================================================
# OLLAMA LLM CONFIGURATION
# =================================================================
# Base URL for the Ollama API. 
# In a Docker Compose network, use the service name 'http://ollama:11434'.
# For local development outside Docker, use 'http://localhost:11434'.
OLLAMA_BASE_URL=http://ollama:11434

# Model name to be used for general tasks
OLLAMA_MODEL=qwen2.5-coder:3b-instruct-q4_0

# Model name for reasoning and complex financial analysis
OLLAMA_REASON_MODEL=qwen2.5-coder:3b-instruct-q4_0

# Model name for conversational chat interactions
OLLAMA_CHAT_MODEL=qwen2.5-coder:3b-instruct-q4_0

# =================================================================
# APPLICATION SETTINGS (Optional)
# =================================================================
# Set to 'DEBUG' for detailed logs or 'INFO' for general production logs
LOG_LEVEL=INFO
APP_DEBUG=False